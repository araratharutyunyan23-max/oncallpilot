# ── Claude (the single required secret in Phase 0) ─────────────────────────
ANTHROPIC_API_KEY=
CHAT_MODEL=claude-sonnet-5
CHAT_EFFORT=medium
CHAT_MAX_TOKENS=4096
CACHE_TTL=1h

# ── HTTP / CORS ────────────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# ── Edge guard (operational safety — NOT product auth) ─────────────────────
DEMO_API_KEY=
RATE_LIMIT_PER_MIN=30
RATE_LIMIT_BURST=10
DAILY_SPEND_CAP_USD=5.0
MAX_REQUEST_USD=0.50

# ── Web (client-exposed; baked into the bundle at build time) ──────────────
NEXT_PUBLIC_AGENT_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEMO_API_KEY=

